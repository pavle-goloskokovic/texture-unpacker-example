{
    "name": "texture-unpacker-example",
    "version": "0.1.0",
    "private": true,
    "description": "TextureUnpacker Example",
    "keywords": [
        "texture",
        "packer",
        "texturepacker",
        "codeandweb",
        "unpacker",
        "textureunpacker",
        "pack",
        "unpack",
        "atlas",
